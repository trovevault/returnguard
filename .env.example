# ── Apify Actor (local `apify run` of actor/) ───────────────────────────────
APIFY_TOKEN=            # https://console.apify.com/settings/integrations
SERPAPI_KEY=            # https://serpapi.com  (Google Lens engine)

# ── InsForge edge-function secrets (set via: insforge secrets add <KEY> <VAL>) ─
# The functions also receive INSFORGE_BASE_URL / ANON_KEY / API_KEY automatically.
NEBIUS_API_KEY=         # https://tokenfactory.nebius.com  (Qwen2.5-VL vision)
# APIFY_TOKEN and SERPAPI_KEY are ALSO stored as InsForge secrets (used by verify-return)

# ── Vapi (voice) ─────────────────────────────────────────────────────────────
VAPI_PRIVATE_KEY=       # server-side: create/manage the assistant (scripts)
VAPI_PUBLIC_KEY=        # client-side: hardcoded in web/index.html (publishable)
VAPI_ASSISTANT_ID=      # the ReturnGuard assistant id

# ── Deployed endpoints ───────────────────────────────────────────────────────
INSFORGE_BASE_URL=https://<your-app>.insforge.app
